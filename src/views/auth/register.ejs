<%- include('../partials/header') %>
    <div class="auth-container">
        <h2>Create New Account</h2>
        
        <% if (locals.error === 'exists') { %>
            <div class="alert error" style="color: #e11d48; margin-bottom: 1rem; font-weight: 500;">
                Email or Username already exists.
            </div>
        <% } %>
        <% if (locals.error === 'server') { %>
            <div class="alert error" style="color: #e11d48; margin-bottom: 1rem; font-weight: 500;">
                System error. Please try again.
            </div>
        <% } %>

        <form action="/auth/register" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" placeholder="e.g. learner123" required>
            </div>
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Min. 6 characters" required>
            </div>

            <div class="form-group">
                <label>You are a:</label>
                <div class="role-selection">
                    <label class="role-option">
                        <input type="radio" name="role" value="student" checked onchange="toggleCertificate()">
                        <span class="role-label">📚 Student</span>
                    </label>
                    <label class="role-option">
                        <input type="radio" name="role" value="instructor" onchange="toggleCertificate()">
                        <span class="role-label">🎓 Instructor</span>
                    </label>
                </div>
            </div>

            <div class="form-group" id="certificate-group" style="display: none;">
                <label for="certificate">Instructor Certificate (PDF/Image)</label>
                <input type="file" id="certificate" name="certificate" accept=".pdf,.jpg,.jpeg,.png">
                <small style="color: var(--text-muted); display: block; margin-top: 0.5rem;">
                    Instructor accounts need to be approved by an Admin before use.
                </small>
            </div>

            <button type="submit" class="btn">Sign Up</button>
        </form>
        <p class="auth-footer">Already have an account? <a href="/login">Login here</a></p>
    </div>

    <script>
        function toggleCertificate() {
            const certGroup = document.getElementById('certificate-group');
            const isInstructor = document.querySelector('input[name="role"][value="instructor"]').checked;
            certGroup.style.display = isInstructor ? 'block' : 'none';
        }
    </script>
<%- include('../partials/footer') %>
