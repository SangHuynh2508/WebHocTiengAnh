<%- include('../partials/header') %>
    <div class="auth-container">
        <h2>Welcome Back</h2>
        
        <% if (locals.error === 'invalid') { %>
            <div class="alert error" style="color: #e11d48; margin-bottom: 1rem; font-weight: 500;">
                Invalid email or password. Please try again.
            </div>
        <% } %>
        <% if (locals.error === 'pending') { %>
            <div class="alert error" style="color: #d97706; margin-bottom: 1rem; font-weight: 500;">
                Your instructor account is pending admin approval.
            </div>
        <% } %>
        <% if (locals.error === 'server') { %>
            <div class="alert error" style="color: #e11d48; margin-bottom: 1rem; font-weight: 500;">
                System error. Please try again.
            </div>
        <% } %>

        <form action="/auth/login" method="POST">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn">Login</button>
        </form>
        <p class="auth-footer">Don't have an account? <a href="/register">Register now</a></p>
    </div>
<%- include('../partials/footer') %>
