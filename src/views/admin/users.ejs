<%- include('../partials/header') %>
    <div class="study-header">
        <a href="/admin" class="back-link">← Back to Dashboard</a>
        <h2>User Management</h2>
    </div>

    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(u => { %>
                    <tr>
                        <td><%= u.username %></td>
                        <td><%= u.email %></td>
                        <td>
                            <% if (u.role === 'instructor') { %>
                                <span class="badge badge-instructor">🎓 Instructor</span>
                            <% } else { %>
                                <span class="badge badge-beginner">📚 Student</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (!u.isApproved) { %>
                                <span class="badge badge-pending">⏳ Pending</span>
                            <% } else { %>
                                <span class="badge badge-approved">✅ Approved</span>
                            <% } %>
                        </td>
                        <td><%= u.createdAt.toLocaleDateString('en-US') %></td>
                        <td class="action-cell">
                            <% if (u.role === 'instructor' && !u.isApproved) { %>
                                <form action="/admin/users/<%= u._id %>/approve" method="POST" style="display:inline;">
                                    <button type="submit" class="btn-approve">Approve</button>
                                </form>
                            <% } %>
                            <% if (u.instructorCertificate) { %>
                                <a href="/uploads/<%= u.instructorCertificate %>" target="_blank" class="btn-view">Certificate</a>
                            <% } %>
                            <form action="/admin/users/<%= u._id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this user?')">
                                <button type="submit" class="btn-delete">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
<%- include('../partials/footer') %>
