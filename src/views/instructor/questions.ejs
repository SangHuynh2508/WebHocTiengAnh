<%- include('../partials/header') %>
    <div class="study-header">
        <a href="/instructor" class="back-link">← Back to Dashboard</a>
        <h2>Exercise List</h2>
    </div>

    <div style="margin-bottom: 2rem;">
        <a href="/instructor/questions/create" class="btn" style="background: var(--accent); color: white;">+ Create New Question</a>
    </div>

    <% if (questions.length === 0) { %>
        <div class="empty-state">
            <p>You haven't created any questions yet.</p>
        </div>
    <% } else { %>
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Question</th>
                        <th>Level</th>
                        <th>Topic</th>
                        <th>Answer</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% questions.forEach(q => { %>
                        <tr>
                            <td><%= q.questionText %></td>
                            <td><span class="badge badge-<%= q.level.toLowerCase() %>"><%= q.level %></span></td>
                            <td><%= q.topic %></td>
                            <td><strong><%= q.correctAnswer %></strong></td>
                            <td>
                                <form action="/instructor/questions/<%= q._id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete?')">
                                    <button type="submit" class="btn-delete">Delete</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
<%- include('../partials/footer') %>
