<%- include('../partials/header') %>
    <div class="study-header">
        <a href="/instructor/questions" class="back-link">← Back to list</a>
        <h2>Create New Question</h2>
    </div>

    <div class="form-container">
        <form action="/instructor/questions" method="POST">
            <div class="form-group">
                <label for="questionText">Question</label>
                <input type="text" id="questionText" name="questionText" placeholder="Enter question content..." required>
            </div>

            <div class="form-group">
                <label for="topic">Topic</label>
                <input type="text" id="topic" name="topic" placeholder="e.g. Grammar, Vocabulary, General">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="option1">Option A</label>
                    <input type="text" id="option1" name="option1" placeholder="Option A" required>
                </div>
                <div class="form-group">
                    <label for="option2">Option B</label>
                    <input type="text" id="option2" name="option2" placeholder="Option B" required>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="option3">Option C</label>
                    <input type="text" id="option3" name="option3" placeholder="Option C" required>
                </div>
                <div class="form-group">
                    <label for="option4">Option D</label>
                    <input type="text" id="option4" name="option4" placeholder="Option D" required>
                </div>
            </div>

            <div class="form-group">
                <label for="correctAnswer">Correct Answer</label>
                <select id="correctAnswer" name="correctAnswer" class="form-select" required>
                    <option value="">Select correct answer...</option>
                </select>
            </div>

            <div class="form-group">
                <label for="level">Level</label>
                <select id="level" name="level" class="form-select" required>
                    <option value="Beginner">Beginner</option>
                    <option value="Intermediate">Intermediate</option>
                    <option value="Advanced">Advanced</option>
                </select>
            </div>

            <button type="submit" class="btn" style="background: var(--accent); color: white; width: 100%;">Create Question</button>
        </form>
    </div>

    <script>
        // Dynamically populate correctAnswer dropdown from option inputs
        const optionInputs = ['option1', 'option2', 'option3', 'option4'];
        const correctSelect = document.getElementById('correctAnswer');

        function updateCorrectOptions() {
            const currentVal = correctSelect.value;
            correctSelect.innerHTML = '<option value="">Select correct answer...</option>';
            optionInputs.forEach(id => {
                const val = document.getElementById(id).value.trim();
                if (val) {
                    const opt = document.createElement('option');
                    opt.value = val;
                    opt.textContent = val;
                    if (val === currentVal) opt.selected = true;
                    correctSelect.appendChild(opt);
                }
            });
        }

        optionInputs.forEach(id => {
            document.getElementById(id).addEventListener('input', updateCorrectOptions);
        });
    </script>
<%- include('../partials/footer') %>
